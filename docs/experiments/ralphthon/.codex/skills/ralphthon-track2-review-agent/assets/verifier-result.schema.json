{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralphthon.local/schemas/verifier-result-1.0.json",
  "title": "VerifierResult",
  "description": "Advisory, field-scoped result from the read-only Track 2 draft verifier. PASS preserves the ReviewDraft unchanged; REPAIR identifies one to three mutable review fields and never rewrites the draft.",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "findings"],
  "properties": {
    "verdict": {
      "enum": ["PASS", "REPAIR"]
    },
    "findings": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/finding"
      }
    }
  },
  "oneOf": [
    {
      "properties": {
        "verdict": {"const": "PASS"},
        "findings": {"maxItems": 0}
      }
    },
    {
      "properties": {
        "verdict": {"const": "REPAIR"},
        "findings": {"minItems": 1, "maxItems": 3}
      }
    }
  ],
  "$defs": {
    "mutableFieldPath": {
      "type": "string",
      "oneOf": [
        {
          "enum": [
            "/summary",
            "/strengths",
            "/weaknesses",
            "/questions",
            "/soundness",
            "/presentation",
            "/contribution",
            "/significance",
            "/originality",
            "/overall_recommendation",
            "/confidence",
            "/comment",
            "/ethics_and_limitations",
            "/evidence_trace"
          ]
        },
        {
          "pattern": "^/(?:strengths|weaknesses|evidence_trace)/[0-9]+(?:/(?:claim|location))?$"
        },
        {
          "pattern": "^/questions/[0-9]+$"
        },
        {
          "pattern": "^/score_rationales/(?:soundness|presentation|contribution|significance|originality|overall_recommendation|confidence)(?:/(?:claim|location))?$"
        }
      ]
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_path", "problem", "location", "instruction"],
      "properties": {
        "field_path": {
          "$ref": "#/$defs/mutableFieldPath",
          "description": "RFC 6901-style path to a mutable review field. Identity and provenance fields are intentionally excluded."
        },
        "problem": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "location": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "pattern": "(?:[Pp]age|[Pp]\\.|[Ss]ection|[Tt]able|[Ff]igure|[Aa]ppendix|[Ss]aved result)"
        },
        "instruction": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    }
  }
}
